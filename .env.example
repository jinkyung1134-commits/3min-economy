SENDER_MODE=dry_run

# Used only when SENDER_MODE=business_webhook.
BUSINESS_MESSAGE_WEBHOOK_URL=
BUSINESS_MESSAGE_API_KEY=

# Comma-separated Korean keywords. Empty means no keyword filtering.
NEWS_KEYWORDS=경제,증시,금리,환율,물가,부동산,반도체,AI,미국,중국

# Comma-separated RSS feed URLs.
NEWS_RSS_FEEDS=https://news.google.com/rss/search?q=%EA%B2%BD%EC%A0%9C%20%EA%B8%88%EC%9C%B5%20%EC%A6%9D%EC%8B%9C&hl=ko&gl=KR&ceid=KR:ko,https://news.google.com/rss/search?q=%EA%B8%88%EB%A6%AC%20%ED%99%98%EC%9C%A8%20%EB%AC%BC%EA%B0%80&hl=ko&gl=KR&ceid=KR:ko

MAX_NEWS_ITEMS=5
MAX_NEWS_AGE_HOURS=48
SUBSCRIBERS_FILE=data/subscribers.json
SENT_FILE=.state/sent_items.json
BRIEFING_OUTPUT_FILE=output/kakao_briefing.txt
SITE_DIR=site

# Optional: used by python -m src.github_sync.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main
